---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: unknown | unknown[];
}

const {
  title = "Mediainc",
  description = "Media Inc — Company builder and consultancy. For 25+ years building, advising and exiting media companies with cultural impact and financial viability.",
  image = "https://mediainc.net/og-image.JPG",
  schema,
} = Astro.props;

const site = Astro.site ?? new URL("https://mediainc.net");
const canonical = new URL(Astro.url.pathname, site).href;
const siteOrigin = site.origin;

// ----- Global JSON-LD: Organization + WebSite + Person (founder) -----
const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteOrigin}/#organization`,
  name: "Media Inc",
  alternateName: "Mediainc",
  url: `${siteOrigin}/`,
  logo: {
    "@type": "ImageObject",
    url: `${siteOrigin}/uploads/2019/06/MEDIA-INC-Logo.png`,
  },
  image: `${siteOrigin}/og-image.JPG`,
  description:
    "Media Inc is a media company builder, advisory and business-intelligence platform. Since 1998 it has built, advised and operated specialized media companies that combine cultural impact with financial viability.",
  foundingDate: "1998",
  founder: { "@id": `${siteOrigin}/#founder` },
  knowsAbout: [
    "Media company building",
    "Editorial strategy",
    "Media consulting",
    "Cultural media",
    "Publishing",
    "Business intelligence for media",
    "Media monetization",
    "Specialized media",
  ],
  areaServed: [
    { "@type": "Country", name: "Mexico" },
    { "@type": "Place", name: "Latin America" },
  ],
  brand: [
    { "@type": "Brand", name: "Residente Food & Drink Media" },
    { "@type": "Brand", name: "JACH" },
    { "@type": "Brand", name: "Documenta" },
  ],
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteOrigin}/#website`,
  url: `${siteOrigin}/`,
  name: "Media Inc",
  description,
  inLanguage: "en",
  publisher: { "@id": `${siteOrigin}/#organization` },
};

const founderLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteOrigin}/#founder`,
  name: "José Antonio Chaurand",
  alternateName: "JACH",
  jobTitle: "Founder",
  description:
    "Mexican entrepreneur, visual artist, publisher, creative director and economist. Founder of Media Inc, La Tempestad, Folio and Residente Food & Drink Media.",
  birthPlace: { "@type": "Place", name: "Celaya, Mexico" },
  birthDate: "1974",
  homeLocation: { "@type": "Place", name: "Monterrey, Mexico" },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Instituto Tecnológico y de Estudios Superiores de Monterrey (ITESM)",
  },
  worksFor: { "@id": `${siteOrigin}/#organization` },
  url: `${siteOrigin}/nosotros/`,
  award: [
    "National Graphic Design Award (publications)",
    "National Prize for the Graphic Arts",
    "Best Magazine Design — Second Design Biennial, INBA (2003)",
    "Endeavor Entrepreneur, Dubai (2013)",
    "Premio al Mérito Restaurantero, CANIRAC Nuevo León (2019)",
  ],
};

const globalGraph = {
  "@context": "https://schema.org",
  "@graph": [organizationLd, websiteLd, founderLd],
};

const extraSchemas = schema
  ? Array.isArray(schema)
    ? schema
    : [schema]
  : [];

const secondaryLinks = [
  { label: "About", href: "/nosotros" },
  { label: "Contact", href: "/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        if (!window.matchMedia || !matchMedia("(pointer: coarse)").matches) return;
        var w = Math.min(window.screen.width, window.screen.height);
        if (w >= 600 && w < 1024) {
          var meta = document.querySelector('meta[name="viewport"]');
          if (meta) meta.setAttribute("content", "width=1024");
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="content-language" content="en" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link
      rel="icon"
      type="image/png"
      href="/favicon/favicon-96x96.png"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-title" content="MediaInc" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content="Mediainc" />
    <meta property="og:site_name" content="Mediainc" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Global JSON-LD: Organization + WebSite + Person (founder) -->
    <script type="application/ld+json" set:html={JSON.stringify(globalGraph)} />
    {extraSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="bg-[#1F1F1F] text-[#EDEDED] font-sans antialiased">
    <div class="max-w-[930px] mx-auto px-4">
      <Header />
      <main>
        <slot />
      </main>
      <footer
        class="mt-8 py-8 text-xs md:text-sm text-[#B5B5B5]"
      >
        <ul class="flex justify-center border-b pb-5 border-white/10 gap-x-4 uppercase">
          {
            secondaryLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-[13px] leading-[1.1] flex flex-col transition-colors hover:underline font-extrabold text-white mx-2"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="pt-5">
          &copy; {new Date().getFullYear()} Mediainc.
        </p>
      </footer>
    </div>
  </body>
</html>
