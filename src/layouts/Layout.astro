---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
}

const { title = "Mediainc" } = Astro.props;

const secondaryLinks = [
  { label: "About", href: "/nosotros" },
  { label: "Contact", href: "/" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="icon"
      type="image/png"
      href="/favicon/favicon-96x96.png"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-title" content="MediaInc" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mediainc.net" />
    <meta property="og:image" content="https://mediainc.net/uploads/2019/06/MEDIA-INC-Logo.png" />
    <meta property="og:image:alt" content="Mediainc Logo" />
    <meta property="og:site_name" content="Mediainc" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content="https://mediainc.net/uploads/2019/06/MEDIA-INC-Logo.png" />

    <!-- Google Structured Data (logo oficial en búsquedas) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Mediainc",
        "url": "https://mediainc.net",
        "logo": "https://mediainc.net/uploads/2019/06/MEDIA-INC-Logo.png"
      }
    </script>
  </head>
  <body class="bg-[#1F1F1F] text-[#EDEDED] font-sans antialiased">
    <div class="max-w-[930px] mx-auto px-4">
      <Header />
      <main>
        <slot />
      </main>
      <footer
        class="mt-8 py-8 text-sm text-[#B5B5B5]"
      >
        <ul class="flex justify-center border-b pb-5 border-white/10 gap-x-4 uppercase">
          {
            secondaryLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-[13px] leading-[1.1] flex flex-col transition-colors hover:underline font-extrabold text-white mx-2"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="pt-5">
          &copy; {new Date().getFullYear()} Mediainc.
        </p>
      </footer>
    </div>
  </body>
</html>
