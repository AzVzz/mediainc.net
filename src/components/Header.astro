---
const navLinks = [
  { line1: "Ideas", href: "/ideas" },
  { line1: "Ventures", href: "/empresas" },
  { line1: "Projects", href: "/proyectos-digitales" },
  { line1: "Consultancy", href: "/consultoria" },
  { line1: "Residente", href: "/residente" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "");
---

<header class="relative flex flex-col md:flex-row md:justify-between md:items-end gap-3 md:gap-0 pt-9.5 mb-4 md:h-[110px]">
  <a href="/" class="inline-block shrink-0">
    <img
      src="/uploads/2019/06/MEDIA-INC-Logo.png"
      alt="Mediainc"
      class="h-12 md:h-18 w-auto mb-[6px] object-contain"
    />
  </a>

  <nav class="flex flex-col items-start md:items-end justify-end w-full md:w-auto md:h-full">
    <div id="google_translate_element" class="hidden"></div>

    <!-- Language dropdown -->
    <div class="relative group mb-2 md:mb-8 max-md:absolute max-md:top-[54px] max-md:right-0 max-md:mb-0" data-dropdown>
      <button class="flex flex-row items-center gap-1.5 cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
        <img id="lang-flag" src="https://flagcdn.com/w40/us.png" alt="Language" class="h-[14px] w-auto" style="filter:grayscale(100%)" />
        <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <ul class="absolute top-full right-0 mt-2 min-w-[130px] bg-black/90 backdrop-blur-sm border border-white/10 rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 z-50">
        <li>
          <button onclick="setLanguage('es')" class="w-full flex items-center gap-2.5 px-4 py-2 text-[12px] font-semibold uppercase tracking-wide text-[#B5B5B5] hover:text-white hover:bg-white/10 transition-colors cursor-pointer">
            <img src="https://flagcdn.com/w40/mx.png" alt="MX" class="h-[12px] w-auto" style="filter:grayscale(100%)" />
            Español
          </button>
        </li>
        <li>
          <button onclick="setLanguage('en')" class="w-full flex items-center gap-2.5 px-4 py-2 text-[12px] font-semibold uppercase tracking-wide text-[#B5B5B5] hover:text-white hover:bg-white/10 transition-colors cursor-pointer">
            <img src="https://flagcdn.com/w40/us.png" alt="US" class="h-[12px] w-auto" style="filter:grayscale(100%)" />
            English
          </button>
        </li>
      </ul>
    </div>

    <ul class="flex flex-nowrap md:flex-wrap gap-y-3 uppercase tracking-wide items-center">
  {
    navLinks.map(({ line1, href, dropdown }) => {
      const active = pathname === href || (dropdown && dropdown.some((d: any) => pathname === d.href));
      const isConsultancy = line1 === "Consultancy";
      const hasRightGap = ["Ideas", "Ventures", "Projects"].includes(line1);
      return (
        <>
          {line1 === "Residente" ? (
            <li class="shrink-0">
              <a
                href={href}
                class={`text-[10px] md:text-[13px] leading-[1.1] flex flex-row items-center gap-1 transition-colors hover:underline font-extrabold uppercase ${active ? "text-white underline" : "text-white"}`}
              >
                <img
                  src="https://residente.mx/fotos/fotos-estaticas/residente-logos/blancos/logo%20residente.mx-99-100.png"
                  alt="Residente"
                  width="92"
                  height="13"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  class="h-[10px] md:h-[13px] mb-[3px] w-[71px] md:w-[92px] object-contain"
                />
              </a>
            </li>
          ) : dropdown ? (
            <li class={`relative group shrink-0 ${hasRightGap ? "mr-2 md:mr-5" : ""}`}>
              <button
                class={`text-[10px] md:text-[13px] leading-[1.1] flex flex-row items-center gap-1 transition-colors hover:underline font-extrabold cursor-pointer uppercase ${active ? "text-white underline" : "text-white"}`}
              >
                {line1}
                <svg class="w-3 h-3 ml-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <ul class="absolute top-full left-0 mt-2 min-w-[160px] bg-black/90 backdrop-blur-sm border border-white/10 rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                {dropdown.map((item: any) => {
                  const subActive = pathname === item.href;
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`block px-4 py-2 text-[12px] font-semibold uppercase tracking-wide transition-colors hover:bg-white/10 ${subActive ? "text-white" : "text-[#B5B5B5] hover:text-white"}`}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </li>
          ) : (
            <li class={`shrink-0 ${hasRightGap ? "mr-2 md:mr-5" : ""}`}>
              <a
                href={href}
                class={`text-[10px] md:text-[13px] leading-[1.1] flex flex-col transition-colors hover:underline font-extrabold text-white ${active ? "text-white underline" : "text-[#B5B5B5]"}`}
              >
                {line1}
              </a>
            </li>
          )}
          {isConsultancy && (
            <li class="text-[#B5B5B5] font-light select-none shrink-0 mx-2 md:mx-3">|</li>
          )}
        </>
      );
    })
  }
</ul>
  </nav>
</header>

<style is:global>
  .goog-te-banner-frame,
  .goog-te-balloon-frame,
  .goog-te-ftab-float,
  .skiptranslate,
  #goog-gt-tt,
  .goog-tooltip,
  .goog-te-spinner-pos {
    display: none !important;
  }
  body {
    top: 0 !important;
    position: static !important;
  }
  .goog-text-highlight {
    background-color: transparent !important;
    box-shadow: none !important;
  }
  #google_translate_element {
    position: absolute;
    opacity: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = "mediainc-lang";

    function clearGoogTransCookies() {
      var hostname = window.location.hostname;
      var parts = hostname.split(".");
      var domains = [""];
      for (var i = 0; i < parts.length - 1; i++) {
        var d = parts.slice(i).join(".");
        domains.push(d);
        domains.push("." + d);
      }
      var paths = ["/", ""];
      var expires = "expires=Thu, 01 Jan 1970 00:00:00 UTC";
      for (var di = 0; di < domains.length; di++) {
        for (var pi = 0; pi < paths.length; pi++) {
          var c = "googtrans=; " + expires;
          if (paths[pi]) c += "; path=" + paths[pi];
          if (domains[di]) c += "; domain=" + domains[di];
          document.cookie = c;
        }
      }
    }

    function setGoogTransCookie(lang) {
      document.cookie = "googtrans=/en/" + lang + "; path=/";
    }

    var choice = null;
    try { choice = sessionStorage.getItem(STORAGE_KEY); } catch (e) {}
    if (choice !== "es" && choice !== "en") choice = "en";

    var flagImg = document.getElementById("lang-flag");

    if (choice === "es") {
      clearGoogTransCookies();
      setGoogTransCookie("es");

      if (flagImg) {
        flagImg.src = "https://flagcdn.com/w40/mx.png";
        flagImg.alt = "Español";
      }

      window.googleTranslateElementInit = function () {
        new google.translate.TranslateElement(
          { pageLanguage: "en", includedLanguages: "en,es", autoDisplay: false },
          "google_translate_element"
        );
      };
      var s = document.createElement("script");
      s.src = "//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit";
      document.head.appendChild(s);
    } else {
      clearGoogTransCookies();
    }

    window.setLanguage = function (lang) {
      if (lang !== "es" && lang !== "en") return;
      try { sessionStorage.setItem(STORAGE_KEY, lang); } catch (e) {}
      clearGoogTransCookies();
      if (lang === "es") setGoogTransCookie("es");
      window.location.reload();
    };
  })();

  // Toggle del dropdown de idioma con click (para touch/tablet)
  (function () {
    var dropdown = document.querySelector("[data-dropdown]");
    if (!dropdown) return;
    var button = dropdown.querySelector("button");
    var menu = dropdown.querySelector("ul");
    if (!button || !menu) return;

    var open = function () {
      menu.style.opacity = "1";
      menu.style.visibility = "visible";
      dropdown.setAttribute("data-open", "true");
    };
    var close = function () {
      menu.style.opacity = "";
      menu.style.visibility = "";
      dropdown.removeAttribute("data-open");
    };

    button.addEventListener("click", function (e) {
      e.stopPropagation();
      if (dropdown.getAttribute("data-open") === "true") close();
      else open();
    });

    document.addEventListener("click", function (e) {
      if (!dropdown.contains(e.target)) close();
    });
  })();
</script>
