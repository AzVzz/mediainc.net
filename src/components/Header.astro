---
const navLinks = [
  {
    line1: "Nosotros",
    href: "/nosotros"
  },
  {
    line1: "Empresas",
    href: "/empresas",
  },
  {
    line1: "Consultoría",
    href: "/consultoria",
  },
  {
    line1: "Proyectos",
    href: "/proyectos-digitales",
    disabled: true,
  },
  {
    line1: "Teorías",
    href: "/teorias",
  },
];

const pathname = Astro.url.pathname.replace(/\/$/, "");
---

<header class="flex flex-row items-end justify-between pt-6 mb-4">
  <a href="/" class="inline-block">
    <img
      src="/uploads/2019/06/lgo_blanco_max.png"
      alt="Mediainc"
      class="h-18 w-auto"
    />
  </a>
  <nav>
    <ul
      class="flex flex-wrap md:gap-x-8 gap-x-4 gap-y-3 text-sm uppercase tracking-wide mt-10"
    >
      {
        navLinks.map(({ line1, href, disabled }) => {
          const active = pathname === href;
          if (disabled) {
            return (
              <li>
                <span
                  aria-disabled="true"
                  class="text-[12px] leading-[1.1] flex flex-col text-white font-extrabold cursor-not-allowed select-none"
                >
                  <span>{line1}</span>
                </span>
              </li>
            );
          }
          return (
            <li>
              <a
                href={href}
                class={`text-[12px] leading-[1.1] flex flex-col transition-colors text-white hover:underline font-extrabold ${active ? "text-white underline" : "text-[#B5B5B5]"}`}
              >
                <span>{line1}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
