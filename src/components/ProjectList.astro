---
interface Project {
  title: string;
  description: string;
  image: string;
  link?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="py-12">
  <ul class="flex flex-col gap-10">
    {projects.map((project) => (
      <li class="flex flex-col md:flex-row gap-6 border-b border-white/10 pb-10 last:border-b-0">
        <div class="md:w-2/5 flex-shrink-0">
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-56 md:h-48 object-cover"
            loading="lazy"
          />
        </div>
        <div class="md:w-3/5 flex flex-col justify-center">
          <h3 class="text-2xl font-bold uppercase tracking-wide text-white">
            {project.title}
          </h3>
          <p class="mt-3 text-[#B5B5B5] leading-relaxed text-sm md:text-base">
            {project.description}
          </p>
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 text-xs uppercase tracking-widest text-white border-b border-white/40 hover:border-white self-start"
            >
              Ver proyecto →
            </a>
          )}
        </div>
      </li>
    ))}
  </ul>
</section>
