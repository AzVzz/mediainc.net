---
import Banner from "../components/Banner.astro";
import Carousel from "./Carousel.astro";

const consultoriaImages = [
  "/uploads/2019/06/BANNERS_VISION.jpg",
  "/uploads/2019/06/BANNER1_teorias.jpg",
  "/uploads/2019/06/BANNER2_teorias.png",
];
---

<section>
  <Carousel
    images={consultoriaImages}
    alt="Mediainc"
    height="h-[310px]"
    fit="cover"
    interval={4500}
    mobileAspect="29/10"
  />

  <div class="flex flex-col ml-auto mt-10 font-medium font-['EB_Garamond']">
    <h1 class="text-center text-[24px] mb-6 leading-[1]">
      Media Inc operates at the intersection of meaning and value.
    </h1>
    <section>
      <p class="text-[32px] md:text-[65px] leading-[1] font-bold text-center">
        A platform where ideas are developed, tested and applied across media,
        projects and cultural analysis.
      </p>
    </section>
  </div>
</section>
