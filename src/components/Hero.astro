---
import Carousel from "./Carousel.astro";

const heroImages = [
  "/uploads/2019/06/BANNERS_CAMBIOS_OK2_empresas.jpg",
  "/images/Folio_banner1.jpg",
  "/images/Residente_banner1.jpg",
  "/images/Tempestad_banner1.jpg",
  "/images/trama_banner_interior1.jpg",
  "/images/Vocero_banner1.jpg",
];
---

<section>
  <Carousel
    images={heroImages}
    alt="Mediainc"
    height="h-[310px]"
    fit="cover"
    interval={4500}
  />

  <div class="flex flex-col ml-auto mt-10 max-w-3xl font-medium max-w-[500px] text-justify font-['EB_Garamond']">
    
  </div>
</section>
