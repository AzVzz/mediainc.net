---
interface Props {
  images: string[];
  alt?: string;
  interval?: number; // ms entre slides
  height?: string;   // tailwind arbitrary, ej. "h-[400px]"
  fit?: "contain" | "cover" | "auto";
}

const {
  images,
  alt = "",
  interval = 4000,
  height = "h-[400px]",
  fit = "contain",
} = Astro.props;

const objectFitClass =
  fit === "cover" ? "object-cover" : fit === "auto" ? "object-contain" : "object-contain";
const autoFit = fit === "auto";
---

<section>
  <div
    class={`carousel relative w-full ${height} overflow-hidden`}
    data-interval={interval}
    data-auto-fit={autoFit ? "true" : "false"}
  >
    <div class="carousel-track relative w-full h-full">
      {images.map((src, i) => (
        <img
          src={src}
          alt={alt}
          class={`carousel-slide absolute inset-0 w-full h-full ${objectFitClass} transition-opacity duration-700 ease-in-out ${i === 0 ? "opacity-100" : "opacity-0"}`}
          data-index={i}
          loading={i === 0 ? "eager" : "lazy"}
        />
      ))}
    </div>

    <button
      type="button"
      class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white text-xl cursor-pointer transition-colors"
      aria-label="Anterior"
    >‹</button>
    <button
      type="button"
      class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white text-xl cursor-pointer transition-colors"
      aria-label="Siguiente"
    >›</button>
  </div>
</section>

<script>
  function initCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLImageElement>(".carousel-slide"));
    const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
    const next = root.querySelector<HTMLButtonElement>(".carousel-next");
    const interval = Number(root.dataset.interval) || 4000;
    const autoFit = root.dataset.autoFit === "true";

    if (autoFit) {
      const applyFit = (img: HTMLImageElement) => {
        if (!img.naturalWidth || !img.naturalHeight) return;
        const isLandscape = img.naturalWidth >= img.naturalHeight;
        img.classList.toggle("object-cover", isLandscape);
        img.classList.toggle("object-contain", !isLandscape);
      };
      slides.forEach((img) => {
        if (img.complete) applyFit(img);
        else img.addEventListener("load", () => applyFit(img), { once: true });
      });
    }

    if (slides.length <= 1) return;

    let current = 0;
    let timer: number | undefined;

    const show = (i: number) => {
      current = (i + slides.length) % slides.length;
      slides.forEach((s, idx) => {
        s.classList.toggle("opacity-100", idx === current);
        s.classList.toggle("opacity-0", idx !== current);
      });
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => show(current + 1), interval);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    prev?.addEventListener("click", () => { show(current - 1); start(); });
    next?.addEventListener("click", () => { show(current + 1); start(); });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    start();
  }

  document.querySelectorAll<HTMLElement>(".carousel").forEach(initCarousel);
</script>
