---
interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  bordered?: boolean;
}

const {
  title,
  subtitle,
  image = "https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=1080&h=400&fit=crop",
  bordered = false,
} = Astro.props;
---

<section>
  <div class={`relative w-full h-[310px] overflow-hidden ${bordered ? "border-2 border-white p-4" : ""}`}>
    <img
      src={image}
      alt={title ?? ""}
      class="absolute inset-0 w-full h-full object-cover"
    />
    {(title || subtitle) && (
      <>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 z-10 p-8">
          {title && <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-wide text-white">{title}</h1>}
          {subtitle && <p class="mt-2 text-[#B5B5B5] max-w-2xl">{subtitle}</p>}
        </div>
      </>
    )}
  </div>
</section>
