---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import ProjectList from "../components/ProjectList.astro";
import { proyectosDigitales } from "../data/projects";
---

<Layout title="Proyectos Digitales — Mediainc">
  <Banner
    image="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&h=300&fit=crop"
  />

  <div class="mt-6">
    <img
      src="/uploads/2019/06/Cimientos_we4_proyectos.jpg"
      alt="Cimientos"
      class="w-full h-auto"
    />
  </div>

  <ProjectList projects={proyectosDigitales} />
</Layout>
