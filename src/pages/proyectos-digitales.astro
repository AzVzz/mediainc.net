---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Projects — Mediainc"
  description="A curated selection from Media Inc's broader portfolio — editorial, digital and distribution projects we've brought to life."
>
  <section class="py-12">
    <h1 class="sr-only">Projects</h1>
    <h2 class="text-[30px] md:text-[45px] leading-[1] font-bold text-center font-['EB_Garamond'] mb-12">The projects featured here are a curated selection from Media Inc's broader portfolio — a glimpse into the range of ideas we've brought to life across editorial, digital, and distribution.</h2>
    <ul id="proyectos-lista" class="flex flex-col md:gap-10"></ul>
  </section>
</Layout>

<script>
  const API_URL = "https://admin.residente.mx/api/mediainc";
  const IMG_BASE = "https://residente.mx";

  // Orden manual: los títulos aquí salen primero en este orden.
  // Los demás quedan después, ordenados por fecha desc.
  const ORDEN_MANUAL = [
    "Guía turística para voluntarios FIFA 2026",
    "Culturall Access Nuevo León",
    "On demand digital content",
    "Héroes del servicio Coca Cola",
    "Recetario Topo Chico",
    "Book oficial de Monterrey.Destino",
    "Agenda del festival Santa Lucía",
    "Libro memoria del Premio Obras Cemex",
    "Ideas que Construyen Vida",
  ];

  const normalizar = (s: string) =>
    (s || "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/\s+/g, " ")
      .trim();

  const ORDEN_MAP = new Map(
    ORDEN_MANUAL.map((t, i) => [normalizar(t), i] as [string, number])
  );

  // Estilos individuales por logo. La key es el título del proyecto.
  // Si un proyecto no aparece aquí se usa LOGO_ESTILO_DEFAULT.
  // Puedes usar cualquier clase de Tailwind: h-8, h-12, h-16, w-auto, w-32,
  // brightness-0 invert (volver blanco), opacity-80, etc.
  const LOGO_ESTILO_DEFAULT = "h-12 w-auto mb-3 object-contain md:self-start";

  const LOGO_ESTILOS: Record<string, string> = {
    "Guía turística para voluntarios FIFA 2026": "h-16 w-auto mb-3 object-contain md:self-start",
    "Culturall Access Nuevo León": "h-14 w-auto mb-3 object-contain md:self-start",
    "On demand digital content": "h-8 w-auto mb-3 object-contain md:self-start",
    "Héroes del servicio Coca Cola": "h-8 w-auto mb-3 object-contain md:self-start",
    "Recetario Topo Chico": "h-10 w-auto mb-3 object-contain md:self-start",
    "Book oficial de Monterrey.Destino": "h-16 w-auto mb-3 object-contain md:self-start",
    "Agenda del festival Santa Lucía": "h-16 w-auto mb-3 object-contain md:self-start",
    "Libro memoria del Premio Obras Cemex": "h-14 w-auto mb-3 object-contain md:self-start",
    "Ideas que Construyen Vida": "h-12 w-auto mb-3 object-contain md:self-start",
  };

  const ESTILO_MAP = new Map(
    Object.entries(LOGO_ESTILOS).map(([k, v]) => [normalizar(k), v] as [string, string])
  );

  async function cargarProyectos() {
    const lista = document.getElementById("proyectos-lista");
    if (!lista) return;

    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error("Error al cargar");
      const proyectos = await res.json();

      if (proyectos.length === 0) return;

      proyectos.sort((a: any, b: any) => {
        const ra = ORDEN_MAP.get(normalizar(a.titulo)) ?? Infinity;
        const rb = ORDEN_MAP.get(normalizar(b.titulo)) ?? Infinity;
        return ra - rb;
        // Sort estable (ES2019+): los proyectos no listados en ORDEN_MANUAL
        // mantienen el orden que devuelve la API (created_at DESC).
      });

      const srcAbsoluta = (url: string): string => {
        if (!url) return "";
        if (/^https?:\/\//i.test(url)) return url;
        return `${IMG_BASE}${url.startsWith("/") ? "" : "/"}${url}`;
      };

      const escapeHtml = (v: string): string =>
        v
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const listaImagenes = (proyecto: any): string[] => {
        const portada = proyecto.imagen ? srcAbsoluta(proyecto.imagen) : null;
        const galeria = Array.isArray(proyecto.imagenes)
          ? [...proyecto.imagenes]
              .sort((a: any, b: any) => (a.orden ?? 0) - (b.orden ?? 0))
              .map((img: any) => srcAbsoluta(img.url))
              .filter(Boolean)
          : [];
        const todas = portada ? [portada, ...galeria] : galeria;
        return Array.from(new Set(todas));
      };

      const bloqueImagen = (imgs: string[], titulo: string): string => {
        if (imgs.length === 0) return "";
        const alt = escapeHtml(titulo);
        if (imgs.length === 1) {
          return `<div class="flex-shrink-0 w-full md:w-auto mx-auto md:mx-0">
            <img src="${imgs[0]}" alt="${alt}" class="w-[650px] h-[500px] object-cover max-w-full" style="--carousel-mobile-aspect: 13/10" loading="lazy" />
          </div>`;
        }
        const slides = imgs
          .map(
            (src, i) => `<img
              src="${src}"
              alt="${alt}"
              class="carousel-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-in-out ${i === 0 ? "opacity-100" : "opacity-0"}"
              data-index="${i}"
              loading="${i === 0 ? "eager" : "lazy"}"
            />`
          )
          .join("");
        return `<div class="flex-shrink-0 w-full md:w-auto mx-auto md:mx-0">
          <div class="carousel relative w-[650px] h-[500px] max-w-full overflow-hidden" style="--carousel-mobile-aspect: 13/10" data-interval="4000">
            <div class="carousel-track relative w-full h-full">${slides}</div>
            <button type="button" class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white text-xl cursor-pointer transition-colors" aria-label="Anterior">‹</button>
            <button type="button" class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white text-xl cursor-pointer transition-colors" aria-label="Siguiente">›</button>
          </div>
        </div>`;
      };

      lista.innerHTML = proyectos
        .map((p: any) => {
          const imgs = listaImagenes(p);
          const tieneImagen = imgs.length > 0;
          const logoSrc = p.logo ? srcAbsoluta(p.logo) : "";
          const fecha = p.fecha_proyecto ? escapeHtml(p.fecha_proyecto) : "";

          return `
          <li class="flex flex-col md:flex-row gap-6 items-center md:items-center max-md:py-8 max-md:border-b max-md:border-white/30">
            ${bloqueImagen(imgs, p.titulo)}
            <div class="${tieneImagen ? "md:w-3/5" : "w-full"} flex flex-col justify-center items-center md:items-start px-2 md:px-0">
              ${logoSrc ? `<img src="${logoSrc}" alt="${p.titulo} logo" class="${ESTILO_MAP.get(normalizar(p.titulo)) ?? LOGO_ESTILO_DEFAULT}" loading="lazy" />` : ""}
              <h3 class="text-[18px] md:text-[25px] font-bold text-white leading-[1.05] text-center md:text-left notranslate" translate="no">${p.titulo}</h3>
              ${p.categoria ? `<span class="mt-4 text-xs text-white font-black uppercase tracking-wider text-center md:text-left">${p.categoria}</span>` : ""}
              ${p.descripcion ? `<p class="mt-3 text-[#B5B5B5] leading-[1.2] text-sm md:text-base text-center md:text-left">${p.descripcion}</p>` : ""}
              ${fecha ? `<time class="mt-4 text-sm text-white uppercase font-bold tracking-wider">${fecha}</time>` : ""}
              ${p.link ? `<a href="${p.link}" target="_blank" rel="noopener noreferrer" class="mt-4 text-xs uppercase tracking-widest text-white border-b border-white/40 hover:border-white md:self-start">Ver proyecto →</a>` : ""}
            </div>
          </li>`;
        })
        .join("");

      lista.querySelectorAll<HTMLElement>(".carousel").forEach((root) => {
        const slides = Array.from(root.querySelectorAll<HTMLImageElement>(".carousel-slide"));
        if (slides.length <= 1) return;
        const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
        const next = root.querySelector<HTMLButtonElement>(".carousel-next");
        let current = 0;
        const show = (i: number) => {
          current = (i + slides.length) % slides.length;
          slides.forEach((s, idx) => {
            s.classList.toggle("opacity-100", idx === current);
            s.classList.toggle("opacity-0", idx !== current);
          });
        };
        prev?.addEventListener("click", () => show(current - 1));
        next?.addEventListener("click", () => show(current + 1));
      });
    } catch (err) {
      console.error(err);
    }
  }

  cargarProyectos();
</script>
