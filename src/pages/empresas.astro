---

<Layout title="Empresas Mediáticas — Mediainc">
  <Carousel
    images={mainBannerImages}
    alt="Empresas Mediáticas"
    height="h-[310px]"
    fit="cover"
    interval={4500}
  />

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={residenteFoodImages}
        alt="Residente Food&Drink Media"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <img
        src="https://residente.mx/fotos/fotos-estaticas/residente-logos/blancos/Residente-FOOD-AND-DRINK-MEDIA.png"
        alt="Residente Food&Drink Media"
        class="w-90 h-auto"
      />
      <time datetime="2015" class="mt-3 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2015 - 2030</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={cimientosImages}
        alt="Cimientos"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Cimientos</h2>
      <time datetime="2018" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2018 - 2020</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={folioImages}
        alt="Folio"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Folio</h2>
      <time datetime="2009" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2009 - 2017</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={tempestadImages}
        alt="La Tempestad"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">La Tempestad</h2>
      <time datetime="1998" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">1998 - 2017</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={voceroImages}
        alt="Vocero"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Vocero</h2>
      <time datetime="2005" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2005 - 2017</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={tramaImages}
        alt="Trama"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Trama</h2>
      <time datetime="2012" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2012 - 2015</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={plataformaImages}
        alt="Plataforma"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Plataforma</h2>
      <time datetime="2009" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2009 - 2014</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

  <section class="mt-6 flex flex-col md:flex-row gap-6 items-start">
    <div class="w-full md:w-2/5">
      <Carousel
        images={residenteImages}
        alt="Residente Ciudad"
        height="h-[280px]"
        fit="auto"
        interval={4500}
      />
    </div>
    <div class="md:w-3/5 flex flex-col justify-center self-stretch">
      <h2 class="text-2xl font-bold uppercase tracking-wide text-white">Residente Ciudad</h2>
      <time datetime="2009" class="mt-1 text-[16px] leading-[1] text-[#B5B5B5] uppercase tracking-wide">2009 - 2014</time>
      <p class="mt-3 text-[#D4D4D4] leading-[1.5] tracking-wide text-[14px]">
        
      </p>
    </div>
  </section>

</Layout>
